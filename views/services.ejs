<section class="services-sec" style="padding-top:120px;background:var(--bg);">
  <div class="container">
    <div class="services-header reveal">
      <div class="sec-tag">Hizmetler</div>
      <h1 class="sec-h2">Tüm Hizmetlerimiz 🌿</h1>
      <p class="sec-p" style="margin:12px auto 0;">Altı uzmanlık alanında bilimsel ve kişiye özel programlarla yanınızdayız.</p>
    </div>

    <div class="services-grid">
      <% services.forEach((s, i) => { %>
      <div class="service-card reveal reveal-d<%= Math.min(i%3+1,3) %>">
        <div class="svc-icon-wrap"><%= s.emoji %></div>
        <h3><%= s.title %></h3>
        <p><%= s.description %></p>
        <ul style="margin:12px 0 18px;display:flex;flex-wrap:wrap;gap:6px;">
          <% s.features.forEach(f => { %>
          <li style="font-size:.72rem;background:var(--teal-lt);color:var(--teal-dk);padding:4px 10px;border-radius:var(--r-f);font-weight:600;"><%= f %></li>
          <% }) %>
        </ul>
        <a href="/iletisim" class="svc-link">Randevu Al →</a>
      </div>
      <% }) %>
    </div>
  </div>
</section>
