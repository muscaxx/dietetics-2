<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="<%= description %>" />
  <meta property="og:title" content="<%= title %>" />
  <meta property="og:description" content="<%= description %>" />
  <meta property="og:type" content="website" />
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&family=Nunito:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
  <%- style %>
</head>
<body class="pg-<%= page %>">
<%- include('../partials/navbar') %>
<main><%- body %></main>
<%- include('../partials/footer') %>
<div class="mobile-nav" id="mobileNav" aria-hidden="true">
  <ul class="mobile-nav-list">
    <li><a href="/"          class="mobile-link <%= page==='home'    ?'active':'' %>">Ana Sayfa</a></li>
    <li><a href="/hakkimda"  class="mobile-link <%= page==='about'   ?'active':'' %>">Hakkımda</a></li>
    <li><a href="/hizmetler" class="mobile-link <%= page==='services'?'active':'' %>">Hizmetler</a></li>
    <li><a href="/blog"      class="mobile-link <%= page==='blog'    ?'active':'' %>">Blog</a></li>
    <li><a href="/iletisim"  class="mobile-link <%= page==='contact' ?'active':'' %>">İletişim</a></li>
  </ul>
  <a href="/iletisim" class="mobile-cta-btn">✨ Randevu Al</a>
</div>
<script src="/js/main.js"></script>
<%- script %>
</body>
</html>
