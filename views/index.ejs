<!-- ══ HERO ══ -->
<section class="hero" id="anasayfa">
  <div class="container">
    <div class="hero-inner">

      <div class="hero-content">
        <div class="hero-tag-pill">Profesyonel Diyet Danışmanlığı</div>
        <h1>Sağlıklı yaşam<br/>için <em>doğru adım</em><br/>buradan başlar ✨</h1>
        <p class="hero-sub">
          Kişiye özel beslenme programları, bilimsel yaklaşım ve sürekli motivasyonla hedeflerinize ulaşın. Her beden farklıdır — planınız da öyle olsun.
        </p>
        <div class="hero-btns">
          <a href="/iletisim" class="btn btn-white">📅 Ücretsiz Görüşme Al</a>
          <a href="/hizmetler" class="btn btn-ghost-teal">Hizmetleri Keşfet →</a>
        </div>
        <div class="hero-stats">
          <div class="stat-pill">
            <div>
              <div class="stat-num">500<span style="color:#B2F5EA">+</span></div>
              <div class="stat-lbl">Mutlu danışan</div>
            </div>
          </div>
          <div class="stat-pill">
            <div>
              <div class="stat-num">8<span style="color:#B2F5EA">+</span></div>
              <div class="stat-lbl">Yıl deneyim</div>
            </div>
          </div>
          <div class="stat-pill">
            <div>
              <div class="stat-num">%<span style="color:#B2F5EA">98</span></div>
              <div class="stat-lbl">Başarı oranı</div>
            </div>
          </div>
        </div>
      </div>

      <div class="hero-card">
        <div class="hero-avatar">Z</div>
        <div class="hero-card-name"><%= site.dietitian %></div>
        <div class="hero-card-role">Klinik Diyetisyen & Beslenme Uzmanı</div>
        <div class="hero-badges">
          <span class="hero-badge">🎓 Hacettepe Üniversitesi</span>
          <span class="hero-badge">🏅 Klinik Beslenme</span>
          <span class="hero-badge">🌿 Holistik Yaklaşım</span>
          <span class="hero-badge">💻 Online Danışmanlık</span>
        </div>
        <div class="hero-card-rating">
          <span class="stars">★★★★★</span>
          <strong> 4.9</strong> — 200+ değerlendirme
        </div>
      </div>

    </div>
  </div>
</section>

<!-- ══ SERVICES ══ -->
<section class="services-sec" id="hizmetler">
  <div class="container">
    <div class="services-header reveal">
      <div class="sec-tag">Hizmetler</div>
      <h2 class="sec-h2">Size özel destek alanları</h2>
      <p class="sec-p" style="margin:12px auto 0;">Altı uzmanlık alanında bilimsel, kişiye özel programlarla hedeflerinize birlikte ulaşalım.</p>
    </div>

    <div class="services-grid">
      <% services.forEach((s, i) => { %>
      <div class="service-card reveal reveal-d<%= Math.min(i%3+1,3) %>">
        <div class="svc-icon-wrap"><%= s.emoji %></div>
        <h3><%= s.title %></h3>
        <p><%= s.description %></p>
        <a href="/iletisim" class="svc-link">Randevu Al <span>→</span></a>
      </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- ══ ABOUT ══ -->
<section class="about-sec" id="hakkimda">
  <div class="about-blob"></div>
  <div class="container">
    <div class="about-inner">

      <div class="about-visual-wrap reveal">
        <div class="about-photo-box">ZA</div>
        <div class="about-exp-card">
          <div class="about-exp-num">8+</div>
          <div class="about-exp-lbl">Yıl deneyim</div>
        </div>
        <div class="about-happy-card">
          <div class="about-happy-num">500+</div>
          <div class="about-happy-lbl">Mutlu danışan 🎉</div>
        </div>
      </div>

      <div class="about-text reveal reveal-d1">
        <div class="sec-tag">Hakkımda</div>
        <h2>Sağlığınız için<br/>bütünsel bir bakış açısı 💚</h2>
        <p>Hacettepe Üniversitesi Beslenme ve Diyetetik mezunuyum. 8 yılı aşkın klinik deneyimimle her danışanımın yaşam tarzını ve sağlık hedeflerini anlayarak gerçekçi, sürdürülebilir planlar hazırlıyorum.</p>
        <p>Diyet bir ceza değil — kendinize yaptığınız en güzel yatırımdır. Açlık hissetmeden, keyifle yiyerek değişim mümkün!</p>
        <div class="cert-grid">
          <div class="cert-chip"><span class="cert-chip-icon">🎓</span>Hacettepe Üniversitesi</div>
          <div class="cert-chip"><span class="cert-chip-icon">🏅</span>Klinik Beslenme Sertifikası</div>
          <div class="cert-chip"><span class="cert-chip-icon">💪</span>Sporcu Beslenmesi Uzmanlığı</div>
          <div class="cert-chip"><span class="cert-chip-icon">👶</span>Pediatrik Beslenme Eğitimi</div>
          <div class="cert-chip"><span class="cert-chip-icon">🤰</span>Perinatal Beslenme Sertifikası</div>
          <div class="cert-chip"><span class="cert-chip-icon">🧬</span>Diyabet Yönetimi Eğitimi</div>
        </div>
        <a href="/iletisim" class="btn btn-primary">Tanışmak İstiyorum ✨</a>
      </div>

    </div>
  </div>
</section>

<!-- ══ TESTIMONIALS ══ -->
<section class="testi-sec" id="basariler">
  <div class="container">
    <div class="testi-header reveal">
      <div class="sec-tag">Başarı Hikayeleri</div>
      <h2 class="sec-h2">Danışanlarım ne diyor? 💬</h2>
      <p class="sec-p" style="margin:12px auto 0;">500'den fazla mutlu danışanın değişim hikayelerinden bazıları.</p>
    </div>

    <div class="testi-grid">
      <% testimonials.forEach((t, i) => { %>
      <div class="testi-card reveal reveal-d<%= i %>">
        <div class="testi-quote-mark">"</div>
        <div class="testi-stars"><%= '★'.repeat(t.rating) %></div>
        <p class="testi-text"><%= t.quote %></p>
        <div class="testi-foot">
          <div class="testi-ava"><%= t.initials %></div>
          <div>
            <div class="testi-name"><%= t.name %></div>
            <div class="testi-info"><%= t.age %> yaş • <%= t.service %></div>
          </div>
          <div class="testi-result">
            <strong><%= t.result %></strong>
            <small><%= t.resultLabel %></small>
          </div>
        </div>
      </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- ══ BLOG ══ -->
<section class="blog-sec" id="blog">
  <div class="container">
    <div class="blog-header reveal">
      <h2>Beslenme & Sağlık Rehberi 📖</h2>
      <a href="/blog" class="btn btn-outline">Tüm Yazılar →</a>
    </div>

    <div class="blog-grid">
      <% blogPosts.forEach((post, i) => { %>
      <a href="/blog/<%= post.slug %>" class="blog-card reveal reveal-d<%= i %>">
        <div class="blog-thumb"><%= post.emoji %></div>
        <div class="blog-body">
          <span class="blog-cat"><%= post.category %></span>
          <h3><%= post.title %></h3>
          <p><%= post.excerpt %></p>
          <div class="blog-meta">
            <span><%= post.date %></span>
            <span class="blog-more">Oku →</span>
          </div>
        </div>
      </a>
      <% }) %>
    </div>
  </div>
</section>

<!-- ══ CTA ══ -->
<section class="cta-sec reveal">
  <div class="container">
    <h2>Sağlıklı yaşama ilk adımı<br/>bugün atın! 🌱</h2>
    <p>İlk görüşme tamamen ücretsiz. Hedeflerinizi konuşalım, planınızı birlikte oluşturalım.</p>
    <div class="cta-btns">
      <a href="/iletisim" class="btn btn-white">📅 Randevu Al</a>
      <a href="tel:<%= site.phone %>" class="btn btn-ghost-teal">📞 Hemen Ara</a>
    </div>
  </div>
</section>
